# —— 订阅 / 云端账号（可选）——
# 使用 Neon、Supabase、阿里云 RDS 等 PostgreSQL，连接串示例：
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DATABASE_URL=

# 会话 JWT 签名密钥，至少 16 字符，生产环境请用随机长串
JWT_SECRET=

# —— Google OAuth (optional) ——
# Create OAuth client in Google Cloud Console -> APIs & Services -> Credentials.
# Authorized redirect URI should match GOOGLE_REDIRECT_URI exactly.
# Example (local dev): http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# 新用户默认试用天数（注册时写入 Subscription.validUntil）
SUBSCRIPTION_TRIAL_DAYS=14

# 淘宝店铺链接（登录提醒、未激活提示、首页拦截弹窗使用；不配则默认 hcwnn1122）
# PURCHASE_SHOP_URL=https://hcwnn1122.taobao.com

# —— 邮件（可选；注册页当前为邮箱+密码直连 /api/auth/register，无需发信）——
# 若恢复邮箱验证码注册，需配置 SMTP 或腾讯云 API，并令前端调用 send-code + register-email
# 腾讯云邮件推送（密钥见「访问管理」- API 密钥；若账号仅允许模板发信，需新建模板并填写下面模板 ID）
# TENCENT_SES_SECRET_ID=
# TENCENT_SES_SECRET_KEY=
# TENCENT_SES_FROM="智序 <noreply@mail.yourdomain.com>"
# TENCENT_SES_REGION=ap-hongkong
# TENCENT_SES_TEMPLATE_ID=
# 模板正文变量默认 {{code}}；若模板里用其它名字，例如 {{verify_code}}，则设 TENCENT_SES_TEMPLATE_VAR_CODE=verify_code
# TENCENT_SES_TEMPLATE_VAR_CODE=code
# 也可使用 TENCENTCLOUD_SECRET_ID / TENCENTCLOUD_SECRET_KEY 代替上面 SECRET 变量
# SMTP（已设置 SMTP 密码或企业邮箱等）
# SMTP_HOST= SMTP_PORT=587 SMTP_USER= SMTP_PASS= SMTP_FROM=

# —— 激活码兑换（可选）多条用英文逗号分隔；每条：激活码|天数|套餐标识；天数 0 或 lifetime 表示永久 ——
# 第三段为套餐标识（个人信息页显示中文名）：quote_monthly=仅报价月卡，quote_contract_monthly=报价+合同月卡，contract_monthly=仅合同，lifetime 用天数 0
# SUBSCRIPTION_REDEEM_CODES="CARD-Q-30|30|quote_monthly,CARD-QC-30|30|quote_contract_monthly,VIP|0|lifetime"

# —— 测试账号（prisma seed，可选覆盖）——
# SEED_TEST_EMAIL=
# SEED_TEST_PASSWORD=
# 配置 DATABASE_URL 后执行：npx prisma db seed

# —— 支付 Webhook（后续对接 Stripe 等时填写）——
# STRIPE_WEBHOOK_SECRET=
