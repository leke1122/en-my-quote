// 配置 DATABASE_URL 后执行: npx prisma migrate dev
// 部署前: npx prisma migrate deploy && npx prisma generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 云端账号（可选；未配置数据库时本应用仍仅使用本地 localStorage）
model User {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String            @map("password_hash")
  createdAt    DateTime          @default(now()) @map("created_at")
  subscription Subscription?
  /// 每人一包业务数据（JSON），与本地备份结构对齐
  projectData  UserProjectData?
  paymentOrders PaymentOrder[]
}

/// 用户项目数据（客户/商品/报价/合同等打一包）
model UserProjectData {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 与 DataBackupPayload 同构或子集，由应用约定版本
  payload        Json     @default("{}")
  payloadVersion Int      @default(2) @map("payload_version")
  updatedAt      DateTime @updatedAt @map("updated_at")
}

/// 订阅状态：后续可由支付 Webhook 写入，当前支持注册时试用与后台手工改库
model Subscription {
  id         String    @id @default(cuid())
  userId     String    @unique @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan       String
  status     String
  /// 当前套餐周期开始日（试用/首次激活/续费规则由服务端写入）
  validFrom  DateTime? @map("valid_from")
  validUntil DateTime? @map("valid_until")
  provider   String    @default("manual")
  externalId String?   @map("external_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
}

/// 邮箱注册验证码（短期有效）
model EmailVerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
}

/// 支付订单（用于微信 Native 扫码支付等）
model PaymentOrder {
  id String @id @default(cuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /** wechat */
  provider String
  /** 商户订单号（本系统生成，唯一） */
  outTradeNo String @unique @map("out_trade_no")

  /** SKU（用于映射套餐/时长/权益） */
  sku String
  /** 订单描述（传给微信 description） */
  description String

  /** 金额（分） */
  amountFen Int @map("amount_fen")
  currency  String @default("CNY")

  /** pending | paid | closed | failed */
  status String @default("pending")

  /** 微信返回：prepay_id、code_url、transaction_id */
  wechatPrepayId   String? @map("wechat_prepay_id")
  wechatCodeUrl    String? @map("wechat_code_url")
  wechatTransId    String? @map("wechat_trans_id")

  paidAt    DateTime? @map("paid_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([provider])
}
